# Supabase
# Self-hosted VPS backend (path-prefix proxy through Nginx → Kong):
#   NEXT_PUBLIC_SUPABASE_URL=https://intrustindia.com/api/supabase
# Keys are generated at stack setup time and stored in:
#   /var/www/intrustindia.com/supabase-stack/.env  (on VPS)
#   scripts/supabase-stack/.env.template            (template in repo)
NEXT_PUBLIC_SUPABASE_URL=https://intrustindia.com/api/supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMSIndiaHub
SMSINDIAHUB_USER=
SMSINDIAHUB_PASSWORD=
SMSINDIAHUB_SENDER_ID=
SMSINDIAHUB_TEMPLATE_ID=

# SprintVerify
SPRINT_VERIFY_BASE_URL=
SPRINT_VERIFY_ENV=
SPRINT_VERIFY_PARTNER_ID=
SPRINT_VERIFY_JWT_KEY=
SPRINT_VERIFY_AUTHORIZED_KEY=
SPRINT_VERIFY_PAN_ENDPOINT=
SPRINT_VERIFY_DEV_BYPASS=

# SabPaisa (server)
SABPAISA_INIT_URL=
SABPAISA_CLIENT_CODE=
SABPAISA_USERNAME=
SABPAISA_PASSWORD=
SABPAISA_AUTH_KEY=
SABPAISA_AUTH_IV=
SABPAISA_CALLBACK_URL=

# SabPaisa (client)
NEXT_PUBLIC_SABPAISA_CLIENT_CODE=
NEXT_PUBLIC_SABPAISA_USERNAME=
NEXT_PUBLIC_SABPAISA_PASSWORD=
NEXT_PUBLIC_SABPAISA_AUTH_KEY=
NEXT_PUBLIC_SABPAISA_AUTH_IV=
NEXT_PUBLIC_SABPAISA_ENV=
NEXT_PUBLIC_SABPAISA_INIT_URL=

# App
NEXT_PUBLIC_APP_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Test credentials
TEST_CUSTOMER_EMAIL=
TEST_CUSTOMER_PASSWORD=
TEST_MERCHANT_EMAIL=
TEST_MERCHANT_PASSWORD=
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Omniflow / WhatsApp
OMNIFLOW_BASE_URL= # Default: https://whatsapp.ominiflow.com
OMNIFLOW_API_TOKEN= # Get from: Omniflow Dashboard → Settings → API → API Token
OMNIFLOW_WEBHOOK_SECRET= # Generate a 32-char random string. Paste the SAME value in: Omniflow Dashboard → Company Apps → WebHooks → Secret

# Internal server-to-server auth token (used by wallet-checkout → notify-order)
# Generate with: openssl rand -hex 32
# Must be set in production. Same value must be present on every Next.js instance.
INTERNAL_API_TOKEN=

# Meta WhatsApp Business API
META_WABA_ID= # Get from: Meta Business Manager → WhatsApp → API Setup → WABA ID
META_PHONE_NUMBER_ID= # Get from: Meta Business Manager → WhatsApp → API Setup → Phone Number ID
META_ACCESS_TOKEN= # Generate a permanent token: Meta Business Manager → System Users → Generate Token
META_WEBHOOK_VERIFY_TOKEN= # Self-chosen string. Must match exactly what you enter in the Meta webhook config panel

# Gemini AI (for web chat — direct API, via @google/genai SDK)
# REQUIRED: Set this in .env.local — the most common cause of web chat not working.
GEMINI_API_KEY=   # Get from: https://aistudio.google.com/app/apikey
# OPTIONAL: Override the Gemini model used by the web chat. Defaults to gemini-2.5-flash (dynamic thinking is enabled for accuracy).
GEMINI_MODEL=     # e.g. gemini-2.5-flash, gemini-1.5-pro

# Contact Form / SMTP (used by lib/email/sendContactNotification.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_FROM_EMAIL=noreply@intrustindia.com
CONTACT_NOTIFICATION_EMAIL=info@intrustindia.com
CRON_SECRET=

# OTP Security Pepper
# MUST be set in production to a secure random string (e.g. openssl rand -hex 32).
# If missing in production, the application will refuse to start to avoid insecure legacy hashing.
OTP_PEPPER=
